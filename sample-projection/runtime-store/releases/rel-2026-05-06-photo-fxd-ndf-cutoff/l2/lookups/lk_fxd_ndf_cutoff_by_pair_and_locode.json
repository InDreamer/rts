  "logic": {
    "summary": "Query the cutoff mapping by forward currency-pair order first, then retry the reverse order when the requested field is not populated. The same lookup drives all FXD.NDF fixing rules that need cutoff-derived values.\n",
    "pipeline": [
      {
        "op": "concat",
        "args": [
          "fixing_currency1",
          "fixing_currency2"
        ],
        "out": "forward_pair"
      },
      {
        "op": "concat",
        "args": [
          "fixing_currency2",
          "fixing_currency1"
        ],
        "out": "reverse_pair"
      },
      {
        "op": "compose_key",
        "template": "{forward_pair}|{cutoff_code}",
        "out": "forward_key"
      },
      {
        "op": "lookup_value",
        "key": "{forward_key}",
        "return_field": "requested_field",
        "out": "forward_result"
      },
      {
        "op": "compose_key",
        "template": "{reverse_pair}|{cutoff_code}",
        "out": "reverse_key"
      },
      {
        "op": "lookup_value",
        "key": "{reverse_key}",
        "return_field": "requested_field",
        "out": "reverse_result"
      },
      {
        "op": "coalesce",
        "when": "forward_result is empty",
        "args": [
          "forward_result",
          "reverse_result"
        ],
        "out": "resolved_value"
      }
    ]
  },
