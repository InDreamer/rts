      "source_path": "/FpML/trade/fxSingleLeg/nonDeliverableForward/fixing/quotedCurrencyPair/quoteBasis/text()"
    }
  ],
  "logic": {
    "summary": "Treat the source fixing quoteBasis as an inversion flag when it equals the concatenated input pair; in the inverse case swap the currencies and emit Currency1PerCurrency2, otherwise preserve the source order and emit Currency2PerCurrency1.\n",
    "pipeline": [
      {
        "op": "concat",
        "args": [
          "source_currency1",
          "source_currency2"
        ],
        "out": "source_pair"
      },
      {
        "op": "equals",
        "out": "is_inverse_quote",
        "left": "source_quote_basis",
        "right": "{source_pair}"
      },
      {
        "op": "branch",
        "condition": "is_inverse_quote",
        "then": [
          {
            "op": "assign",
            "from": "source_currency2",
            "out": "target_currency1"
          },
          {
            "op": "assign",
            "from": "source_currency1",
            "out": "target_currency2"
          },
          {
            "op": "constant",
            "value": "Currency1PerCurrency2",
            "out": "target_quote_basis"
          }
        ],
        "else": [
          {
            "op": "assign",
            "from": "source_currency1",
            "out": "target_currency1"
          },
          {
            "op": "assign",
            "from": "source_currency2",
            "out": "target_currency2"
          },
          {
            "op": "constant",
            "value": "Currency2PerCurrency1",
            "out": "target_quote_basis"
          }
        ]
      }
    ]
  },
  "dependencies": [],
  "examples": [
    {
      "name": "sample_usdtwd_inverts",
      "input": {
        "source_currency1": "USD",
        "source_currency2": "TWD",
        "source_quote_basis": "USDTWD"
      },
      "key_decision": {
